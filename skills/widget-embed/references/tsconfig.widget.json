{
  "extends": "./tsconfig.json",
  "include": ["widget/**/*"],
  "compilerOptions": {
    "composite": true,
    "strict": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "preact",
    "types": [],
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.widget.tsbuildinfo"
  }
}
