{
	"name": "present",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "react-router build",
		"dev": "react-router dev",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "wrangler types && react-router typegen && tsc -b",
		"db:generate": "drizzle-kit generate",
		"db:studio": "drizzle-kit studio --config drizzle.config.local.ts",
		"db:studio:remote": "drizzle-kit studio",
		"db:migrate:local": "wrangler d1 migrations apply present --local",
		"db:migrate:remote": "wrangler d1 migrations apply present --remote",
		"deploy": "pnpm run build && wrangler deploy",
		"preview": "pnpm run build && vite preview",
		"cf-typegen": "wrangler types",
		"postinstall": "wrangler types",
		"install-skill": "node scripts/install-skill.mjs",
		"doctor": "node scripts/doctor.mjs"
	},
	"packageManager": "pnpm@9.15.5",
	"dependencies": {
		"@clerk/backend": "^3.5.0",
		"@clerk/hono": "^0.1.33",
		"@clerk/react-router": "^3.3.3",
		"@fontsource-variable/fraunces": "^5.2.9",
		"@fontsource-variable/inter": "^5.2.8",
		"@fontsource-variable/plus-jakarta-sans": "^5.2.8",
		"@fontsource-variable/public-sans": "^5.2.7",
		"@fontsource/ibm-plex-mono": "^5.2.7",
		"@hono/zod-validator": "^0.8.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.45.2",
		"hono": "^4.12.23",
		"isbot": "^5.1.36",
		"lucide-react": "^1.17.0",
		"next-themes": "^0.4.6",
		"radix-ui": "^1.4.3",
		"react": "^19.2.6",
		"react-dom": "^19.2.6",
		"react-router": "^7.10.0",
		"shadcn": "^4.10.0",
		"sonner": "^2.0.7",
		"svix": "^1.95.1",
		"tailwind-merge": "^3.6.0",
		"tw-animate-css": "^1.4.0",
		"ulid": "^3.0.2",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@cloudflare/vite-plugin": "^1.40.0",
		"@cloudflare/vitest-pool-workers": "^0.16.13",
		"@react-router/dev": "^7.10.0",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^22.19.19",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"better-sqlite3": "^12.10.0",
		"drizzle-kit": "^0.31.10",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.3",
		"vite": "^8.0.3",
		"vitest": "^4.1.8",
		"wrangler": "^4.98.0"
	}
}
