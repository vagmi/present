# Copy to .env.local and fill in. Never commit .env.local.
# These VITE_* values are read by the Clerk React components in the browser.

VITE_CLERK_PUBLISHABLE_KEY=pk_test_xxx
VITE_CLERK_SIGN_IN_URL=/sign-in
VITE_CLERK_SIGN_UP_URL=/sign-up
VITE_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/app
VITE_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/app
