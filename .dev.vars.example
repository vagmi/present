# Copy to .dev.vars and fill in. Never commit .dev.vars.
# These are the server-side secrets the baseline (Clerk auth) needs.
# Skills add their own keys on install (e.g. POLAR_ACCESS_TOKEN for billing-polar,
# RESEND_API_KEY for email-resend, SVIX_API_KEY, R2_PUBLIC_BASE_URL).

CLERK_SECRET_KEY=sk_test_xxx
CLERK_PUBLISHABLE_KEY=pk_test_xxx
# Optional: only needed if you wire up the Clerk -> D1 org-sync webhook.
# Orgs are also mirrored lazily on first request, so you can skip this for the workshop.
CLERK_WEBHOOK_SECRET=whsec_xxx

APP_URL=http://localhost:5173
